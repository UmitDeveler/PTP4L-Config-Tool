                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    
                    
                    <!-- Servo Configuration -->
                    <TitledPane text="Servo Configuration" expanded="true" styleClass="section-pane">
                        <VBox spacing="10">
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="NEVER" minWidth="150" prefWidth="200"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="300"/>
                                </columnConstraints>
                                
                                <Label text="Clock Servo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="clock_servoCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                                         promptText="Select servo type" maxWidth="Infinity"/>
										 
								<Label text="First Step Threshold:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="first_step_thresholdField" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                                          promptText="(default: 0.00002 (20 microseconds))"/>
										  
								<Label text="Max Frequency:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextField fx:id="max_frequencyField" GridPane.columnIndex="1" GridPane.rowIndex="2" 
                                          promptText="(default: 900000000 (90 Percent))"/>
								
								<Label text="Msg Interval Request:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
								<CheckBox fx:id="msg_interval_requestCheck" text="" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
								
								<Label text="NTP SHM Segment:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <TextField fx:id="ntpshm_segmentField" GridPane.columnIndex="1" GridPane.rowIndex="4" 
                                          promptText="(default: 0)"/>
								
								<Label text="PI Integral Const:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                <TextField fx:id="pi_integral_constField" GridPane.columnIndex="1" GridPane.rowIndex="5" 
                                          promptText="(default: 0.0)"/>
                                
								<Label text="PI Integral Exponent:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                                <TextField fx:id="pi_integral_exponentField" GridPane.columnIndex="1" GridPane.rowIndex="6" 
                                          promptText="(default: 0.4)"/>
										  
								<Label text="PI Integral Norm Max:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                                <TextField fx:id="pi_integral_norm_maxField" GridPane.columnIndex="1" GridPane.rowIndex="7" 
                                          promptText="(default: 0.3)"/>

								<Label text="PI Integral Scale:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                                <TextField fx:id="pi_integral_scaleField" GridPane.columnIndex="1" GridPane.rowIndex="8" 
                                          promptText="(default: 0.0)"/>

								<Label text="PI Proportional Const:" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                                <TextField fx:id="pi_proportional_constField" GridPane.columnIndex="1" GridPane.rowIndex="9" 
                                          promptText="(default: 0.0)"/>

								<Label text="PI Proportional Exponent:" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
                                <TextField fx:id="pi_proportional_exponentField" GridPane.columnIndex="1" GridPane.rowIndex="10" 
                                          promptText="(default: -0.3)"/>
										  
								<Label text="PI Proportional Norm Max:" GridPane.columnIndex="0" GridPane.rowIndex="11"/>
                                <TextField fx:id="pi_proportional_norm_maxField" GridPane.columnIndex="1" GridPane.rowIndex="11" 
                                          promptText="(default: 0.7)"/>

								<Label text="PI Proportional Scale:" GridPane.columnIndex="0" GridPane.rowIndex="12"/>
                                <TextField fx:id="pi_proportional_scaleField" GridPane.columnIndex="1" GridPane.rowIndex="12" 
                                          promptText="(default: 0.0)"/>
										  
								<Label text="Sanity Freq Limit:" GridPane.columnIndex="0" GridPane.rowIndex="13"/>
                                <TextField fx:id="sanity_freq_limitField" GridPane.columnIndex="1" GridPane.rowIndex="13" 
                                          promptText="(default: 200000000 (20 Percent))"/>
										  
								<Label text="Servo Num Offset Values:" GridPane.columnIndex="0" GridPane.rowIndex="14"/>
                                <TextField fx:id="servo_num_offset_valuesField" GridPane.columnIndex="1" GridPane.rowIndex="14" 
                                          promptText="(default: 10)"/>
										  
								<Label text="Servo Offset Threshold:" GridPane.columnIndex="0" GridPane.rowIndex="15"/>
                                <TextField fx:id="servo_offset_thresholdField" GridPane.columnIndex="1" GridPane.rowIndex="15" 
                                          promptText="(default: 0)"/>
										  
                                <Label text="Step Threshold:" GridPane.columnIndex="0" GridPane.rowIndex="16"/>
                                <TextField fx:id="step_thresholdField" GridPane.columnIndex="1" GridPane.rowIndex="16" 
                                          promptText="Seconds (default: 0.0)"/>
                                
                                <Label text="Write Phase Mode:" GridPane.columnIndex="0" GridPane.rowIndex="17"/>
								<CheckBox fx:id="write_phase_modeCheck" text="" GridPane.columnIndex="1" GridPane.rowIndex="17"/>
                                
                                
                            </GridPane>
                        </VBox>
                    </TitledPane>
 
                </VBox>
            </ScrollPane>
        </Tab>
        
        <!-- Port Options Tab -->
        
        
        <!-- Interface & Execution Tab -->
        <Tab text="Execution">
            <ScrollPane fitToWidth="true">
                <VBox spacing="15" styleClass="content-container">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    
                    <!-- Interface Configuration -->
                    <TitledPane text="Interface Configuration" expanded="true" styleClass="section-pane">
                        <VBox spacing="10">
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="NEVER" minWidth="150" prefWidth="200"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="300"/>
                                </columnConstraints>
                                
                                <Label text="Interface Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="interfaceNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                                          promptText="e.g., eth0, enp0s3"/>
                            </GridPane>
                        </VBox>
                    </TitledPane>
                    
                    <!-- Master/Slave Configuration -->
                    <TitledPane text="Master/Slave Configuration" expanded="true" styleClass="section-pane">
                        <VBox spacing="10">
                            <CheckBox fx:id="masterModeCheck" text="Master Mode (checked: -m only, unchecked: -m -s)"/>
                            <Label text="Note: When checked, runs as master (-m). When unchecked, runs as slave (-m -s)." 
                                   style="-fx-font-style: italic; -fx-text-fill: #666666;"/>
                        </VBox>
                    </TitledPane>
                    
                    <!-- Execution Options -->
                    <TitledPane text="Execution Options" expanded="true" styleClass="section-pane">
                        <VBox spacing="10">
                            <HBox spacing="20">
                                <CheckBox fx:id="useSudoCheck" text="Use Sudo"/>
                                <CheckBox fx:id="quietCheck" text="Quiet (-q)"/>
                            </HBox>
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="NEVER" minWidth="150" prefWidth="200"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="300"/>
                                </columnConstraints>
                                
                                <Label text="Print Level:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="printLevelField" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                                          promptText="0-6 (default: 6)"/>
                            </GridPane>
                        </VBox>
                    </TitledPane>
                </VBox>
            </ScrollPane>
        </Tab>
        
    </TabPane>

    <!-- Save Configuration and Control Buttons -->
    <HBox spacing="10" alignment="CENTER" styleClass="control-buttons">
        <Button fx:id="saveConfigButton" text="Save &amp; Upload Config" styleClass="save-button"/>
        <Button fx:id="startButton" text="Start PTP4L" styleClass="start-button"/>
        <Button fx:id="stopButton" text="Stop PTP4L" styleClass="stop-button"/>
        <Button fx:id="clearButton" text="Clear Output" styleClass="clear-button"/>
    </HBox>

    <!-- Output Section -->
    <TitledPane text="Output" expanded="true" styleClass="section-pane">
        <VBox spacing="30">
            <TextArea fx:id="outputArea" promptText="PTP4L output will appear here..."
                      VBox.vgrow="ALWAYS" styleClass="output-area" prefRowCount="30"/>
        </VBox>
    </TitledPane>

</VBox> 
